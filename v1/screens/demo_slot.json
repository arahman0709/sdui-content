{
  "type": "column",
  "id": "slot_demo",
  "style": {
    "padding": { "topDp": 16, "bottomDp": 16, "startDp": 16, "endDp": 16 }
  },
  "children": [
    {
      "type": "text",
      "id": "slot_title",
      "text": "Slot overrides below:"
    },
    {
      "type": "spacer",
      "id": "gap",
      "heightDp": 8
    },
    {
      "type": "slot",
      "id": "user_card_1",
      "ref": "user_card",
      "overrides": {
        "user_name": {
          "text": "Alice Smith",
          "style": { "padding": { "topDp": 12, "bottomDp": 12, "startDp": 12, "endDp": 12 }, "background": { "color": { "type": "hex", "value": "#10B981" } } }
        }
      }
    },
    {
      "type": "spacer",
      "id": "gap2",
      "heightDp": 8
    },
    {
      "type": "slot",
      "id": "user_card_2",
      "ref": "user_card",
      "overrides": {
        "user_name": {
          "text": "Bob Jones",
          "style": { "padding": { "topDp": 12, "bottomDp": 12, "startDp": 12, "endDp": 12 }, "background": { "color": { "type": "hex", "value": "#F59E0B" } } }
        }
      }
    }
  ]
}
