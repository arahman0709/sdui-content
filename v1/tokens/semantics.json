{
  "version": "1.0.0",
  "tokens": {
    "color": {
      "$type": "color",
      "brand": {
        "primary":    { "$value": "{color.palette.blue.500}" },
        "on-primary": { "$value": "{color.palette.neutral.0}" }
      },
      "surface": {
        "default":    { "$value": "{color.palette.neutral.0}" },
        "subtle":     { "$value": "{color.palette.neutral.100}" },
        "on-default": { "$value": "{color.palette.neutral.900}" }
      },
      "status": {
        "success": { "$value": "{color.palette.green.500}" },
        "error":   { "$value": "{color.palette.red.500}" }
      }
    }
  }
}
